{
  "name": "xelent/xelentwatch",
  "description": "Xelentwatch - Self-hosted telemetry client for Laravel applications",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Xelent",
      "email": "dev@xelent.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-sockets": "*",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/queue": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0|^9.0"
  },
  "autoload": {
    "psr-4": {
      "Laravel\\Xelentwatch\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Laravel\\Xelentwatch\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Laravel\\Xelentwatch\\XelentwatchServiceProvider"
      ],
      "aliases": {
        "Xelentwatch": "Laravel\\Xelentwatch\\Facades\\Xelentwatch"
      }
    },
    "branch-alias": {
      "dev-main": "1.0-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
